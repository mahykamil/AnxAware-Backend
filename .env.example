# MongoDB
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/anxaware

# Auth
JWT_SECRET=your_secure_secret_here

# Server
PORT=3000

# Email (Nodemailer / SMTP) — required for emergency alerts
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=AnxAware Alerts <your-email@gmail.com>

# Dialogflow (chatbot)
DIALOGFLOW_PROJECT_ID=
DIALOGFLOW_CLIENT_EMAIL=
DIALOGFLOW_PRIVATE_KEY=
